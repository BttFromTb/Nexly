# Nexly Configuration
# ========================

# Apify API Token (Lead verisi çekmek için)
APIFY_API_KEY=your_apify_key_here

# OpenAI / Gemini API Key (Kişiselleştirilmiş e-posta yazmak için)
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here

# E-posta SMTP Ayarları (Gmail vs.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Your_Name_Here

# Takip Ayarları (gün cinsinden)
FOLLOWUP_DAYS_FIRST=3
FOLLOWUP_DAYS_SECOND=5

# Sunucu
PORT=3000

